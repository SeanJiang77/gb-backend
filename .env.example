NODE_ENV=development
PORT=3000

# Preferred multi-origin CORS whitelist. Comma-separated.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Backward-compatible single-origin fallback. Used only when CORS_ALLOWED_ORIGINS/CORS_ORIGINS is absent.
# CORS_ORIGIN=http://localhost:5173

MONGO_URI=mongodb://127.0.0.1:27017/godsbooklet
